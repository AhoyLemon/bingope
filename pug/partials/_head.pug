head
  meta(charset="utf-8")
  if pageTitle
    title #{pageTitle} | #{siteTitle}
  else
    title= siteTitle
  meta(http-equiv="X-UA-Compatible" content="IE=edge,chrome=1")
  link(href=assetPath + "css/site.css?lastUpdated=" + lastUpdated rel="stylesheet")
  link(rel="preconnect" href="https://fonts.googleapis.com")
  link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
  link(href="https://fonts.googleapis.com/css2?family=Zilla+Slab:wght@500;700&display=swap" rel="stylesheet")
  meta(name="viewport" content="width=device-width, initial-scale=1")
  meta(name="description" content=description)
  meta(http-equiv="last-modified" content=lastUpdated)

  //---- Favicon and Social stuff commented out until you have the assets for it.
  //-include _favicons.pug
  //-include _social.pug


  //-- Default schema included, but PLEASE edit it.
  //-include _schema.pug
