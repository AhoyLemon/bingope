- const pageTitle = null
- const assetPath = ""
-
  const players = [
    { name: "Lemon", slug: "lemon" },
    { name: "Simone", slug: "simone" },
    { name: "Angie", slug: "angie" },
    { name: "Mike", slug: "mike" },
    { name: "Victor", slug: "victor" },
  ]
include partials/_variables
include partials/_mixins

doctype html
html(lang="en")
  include partials/_head.pug

  body
    #app.site-shell
      header.site-header
        p.eyebrow 2026 Minnesota State Fair
        h1 BINGOPE
        p Choose your Card. The bingo grids are coming next.

      main
        //- Native GET form: submitting navigates to card/?card=<name>, no JS needed.
        form.name-entry(action="card/" method="get")
          label(for="CardName") Enter your name
          input#CardName(type="text" name="card" required autocomplete="off")
          button(type="submit") Get my Card

        nav(aria-label="Player Cards")
          ul.card-links
            each player in players
              li
                a.card-link(href="card/?card=" + player.slug) #{player.name}'s Card

    include partials/_javascripts
