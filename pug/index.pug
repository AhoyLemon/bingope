- const pageTitle = null
- const assetPath = ""
include partials/_variables
include partials/_mixins

doctype html
html(lang="en")
  include partials/_head.pug

  body.entry-page
    #app.site-shell.entry-shell
      main.entry-ticket
        header.entry-ticket__header
          p.eyebrow 2026 Minnesota State Fair
          h1 BINGOPE
          p.entry-ticket__lede Your own fair day, one square at a time.

        //- The native GET action is the no-JS fallback. _nameEntry.ts cleans
        //- whitespace while preserving the player-entered casing in the URL.
        form.name-entry(action="card/" method="get")
          label(for="CardName") What’s your name?
          input#CardName(type="text" name="card" required autocomplete="name")
          button(type="submit") Get My Card

        p.entry-ticket__help
          a(href="help/") What is this?

    include partials/_javascripts
