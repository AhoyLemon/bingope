- const pageTitle = "Your Card"
- const assetPath = "../"
include partials/_variables
include partials/_mixins

doctype html
html(lang="en")
  include partials/_head.pug

  body.card-page
    #app.site-shell
      main.card-shell(v-cloak)
        template(v-if="hasCard")
          header.card-ticket.ticket-mask
            span.card-ticket__perforations.card-ticket__perforations--left(aria-hidden="true")
            span.card-ticket__perforations.card-ticket__perforations--right(aria-hidden="true")
            .card-ticket__paper.ticket-mask
              .card-ticket__rule.ticket-mask
                .card-ticket__rule-gap.ticket-mask
                  .card-ticket__inner-rule.ticket-mask
                    .card-ticket__inside.ticket-mask
                      .card-ticket__star-rail.card-ticket__star-rail--left(aria-hidden="true")
                        span ★
                        span ★
                        span ★
                        span ★
                        span ★
                      .card-ticket__brand
                        h1 BINGOPE
                        p.card-ticket__owner
                          span.card-ticket__owner-name {{ cardLabel }}
                      .card-ticket__star-rail.card-ticket__star-rail--right(aria-hidden="true")
                        span ★
                        span ★
                        span ★
                        span ★
                        span ★

          section.bingo-board(aria-label="Bingo card")
            p.bingo-board__announcement(aria-live="polite" aria-atomic="true") {{ bingoAnnouncement }}
            .bingo-grid(
              ref="bingoGrid"
              :aria-busy="celebrating ? 'true' : undefined"
            )
              svg.bingo-lines(viewBox="0 0 500 500" preserveAspectRatio="none" aria-hidden="true")
                defs
                  linearGradient#bingo-sharpie-red(x1="0%" y1="8%" x2="100%" y2="92%")
                    stop(offset="0%" stop-color="#8e2430")
                    stop(offset="43%" stop-color="#d83b3c")
                    stop(offset="72%" stop-color="#b72731")
                    stop(offset="100%" stop-color="#8f1d2d")
                path.bingo-line(
                  v-for="line in bingoLines"
                  :key="line.id"
                  :class="bingoLineClasses(line)"
                  :d="bingoLinePath(line)"
                  :style="{ display: bingos[line.id] ? '' : 'none' }"
                  pathLength="1"
                )
              button.bingo-square(
                v-for="(square, squareIndex) in cardSquares"
                :key="square.id"
                :class="squareClasses(square, squareIndex)"
                :aria-pressed="isMarked(square.id)"
                :aria-label="square.label + (isMarked(square.id) ? ', marked' : ', unmarked')"
                @click="openSquare(square, $event)"
                type="button"
              )
                svg.bingo-square__dauber(viewBox="0 0 100 100" aria-hidden="true")
                  defs
                    linearGradient(
                      :id="'dauber-colors-' + square.id"
                      x1="8%"
                      y1="10%"
                      x2="92%"
                      y2="88%"
                      :gradientTransform="'rotate(' + ((squareIndex % 5) * 18 - 36) + ' 50 50)'"
                    )
                      stop(offset="0%" stop-color="#82d8f8")
                      stop(offset="24%" stop-color="#2db2ec")
                      stop(offset="49%" stop-color="#0d92d4")
                      stop(offset="73%" stop-color="#61c9f3")
                      stop(offset="100%" stop-color="#1ca5e5")
                    filter(
                      :id="'dauber-' + square.id"
                      x="-12%"
                      y="-12%"
                      width="124%"
                      height="124%"
                      color-interpolation-filters="sRGB"
                    )
                      feTurbulence(
                        type="fractalNoise"
                        baseFrequency="0.08"
                        numOctaves="3"
                        :seed="squareIndex + 11"
                        result="edgeNoise"
                      )
                      feDisplacementMap(
                        in="SourceGraphic"
                        in2="edgeNoise"
                        scale="6.5"
                        xChannelSelector="R"
                        yChannelSelector="G"
                        result="distorted"
                      )
                      feTurbulence(
                        type="fractalNoise"
                        baseFrequency="0.55"
                        numOctaves="3"
                        :seed="squareIndex + 31"
                        result="grain"
                      )
                      feColorMatrix(in="grain" type="luminanceToAlpha" result="grainAlpha")
                      feComponentTransfer(in="grainAlpha" result="inkMask")
                        feFuncA(type="table" tableValues="0.22 0.5 0.82 1")
                      feComposite(in="distorted" in2="inkMask" operator="in" result="grainyInk")
                      feTurbulence(
                        type="fractalNoise"
                        baseFrequency="0.075"
                        numOctaves="2"
                        :seed="squareIndex + 51"
                        result="blotches"
                      )
                      feColorMatrix(in="blotches" type="luminanceToAlpha" result="blotchAlpha")
                      feComponentTransfer(in="blotchAlpha" result="blotchMask")
                        feFuncA(type="table" tableValues="0 0.15 0.6 0.95")
                      feComponentTransfer(in="blotchAlpha" result="darkBlotchMask")
                        feFuncA(type="table" tableValues="0.95 0.55 0.15 0")
                      feFlood(flood-color="#087fbd" flood-opacity="0.46" result="darkBlue")
                      feComposite(in="darkBlue" in2="darkBlotchMask" operator="in" result="darkBlotches")
                      feComposite(in="darkBlotches" in2="distorted" operator="in" result="darkBlotchesInside")
                      feFlood(flood-color="#a6e4fb" flood-opacity="0.62" result="lightBlue")
                      feComposite(in="lightBlue" in2="blotchMask" operator="in" result="lightBlotches")
                      feComposite(in="lightBlotches" in2="distorted" operator="in" result="lightBlotchesInside")
                      feBlend(in="grainyInk" in2="darkBlotchesInside" mode="multiply" result="shadowedInk")
                      feBlend(in="shadowedInk" in2="lightBlotchesInside" mode="screen")
                  path(
                    :d="dauberPaths[squareIndex % dauberPaths.length]"
                    :filter="'url(#dauber-' + square.id + ')'"
                    :fill="'url(#dauber-colors-' + square.id + ')'"
                    :fill-opacity="0.7 + (squareIndex % 5) * 0.035"
                  )
                span.bingo-square__text {{ square.label }}

            button.bingo-celebration(
              v-if="celebrationVisible"
              @click="dismissCelebration"
              @keydown.esc.prevent="dismissCelebration"
              aria-label="Continue playing"
              type="button"
            )
              span.bingo-celebration__message {{ celebrationMessage }}
              span.bingo-celebration__burst
                span(
                  v-for="piece in fairBurst"
                  :key="piece.id"
                  class="bingo-celebration__piece"
                  :style="fairStarStyle(piece)"
                ) ★

          include sections/_dialog.pug

        template(v-else)
          h2 No card yet
          p Head back and pick a name to get your Card.
          a.back-link(href="../") Go to the homepage

    include partials/_javascripts
